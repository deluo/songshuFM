{
  "manifest_version": 3,
  "name": "松鼠FM",
  "description": "搜索、订阅和收听播客，支持 RSS 订阅与离线缓存",
  "version": "1.0.0",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "offscreen",
    "alarms",
    "notifications",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/locales/*.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
